# ──────────────────────────────────────────────────────────────────────
#  Brain Arena environment configuration
# ──────────────────────────────────────────────────────────────────────
#
# Copy to `.env` (Docker Compose) or `.env.local` (next dev) and fill in.
# All values shown in this file are EXAMPLES — never commit real secrets.
#
# See DEPLOYMENT.md for the full guided setup.
# ──────────────────────────────────────────────────────────────────────

# === Required in production ==========================================

# DATABASE_URL — Postgres connection string used by Prisma.
#   Local Docker Compose:  postgresql://brainarena:brainarena@db:5432/brainarena
#   Local dev (host pg):   postgresql://brainarena:brainarena@localhost:5432/brainarena
#   Managed Postgres:      postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require
DATABASE_URL=postgresql://brainarena:brainarena@db:5432/brainarena

# PUBLIC_ORIGIN — Public URL the browser uses to reach Brain Arena.
# REQUIRED in production. Used for Socket.IO CORS and HTTPS-only cookie
# scope. Comma-separate multiple origins (eg. apex + www).
#   Production:  https://brainarena.gg,https://www.brainarena.gg
#   Local dev:   http://localhost:3000
PUBLIC_ORIGIN=https://your-domain.example

# === Optional / safe defaults ========================================

# NODE_ENV — `production` for prod, anything else is treated as dev.
# The Dockerfile already sets this in the runner stage.
# NODE_ENV=production

# PORT — TCP port the Node process listens on. Default 3000.
# PORT=3000

# HOSTNAME — interface to bind. Default 0.0.0.0 (all interfaces).
# Lock to 127.0.0.1 if you front the app with a reverse proxy on the
# same host.
# HOSTNAME=0.0.0.0

# === NOT IMPLEMENTED — schema placeholders only ======================
# Brain Arena does NOT implement payments, wallets, or gambling. The
# variables below exist solely so a future, separately-reviewed
# integration is not a breaking change. Leave them blank / unset.
#
# NETOPIA_MERCHANT_ID=
# NETOPIA_PUBLIC_KEY=
# NETOPIA_PRIVATE_KEY=
# NETOPIA_WEBHOOK_SECRET=
